{
  "name": "openclaw-plugin-lossless-context",
  "version": "0.1.0",
  "description": "Context engine plugin for OpenClaw — lossless vector-backed memory that survives compaction",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "openclaw": {
    "extensions": ["./dist/index.js"]
  },
  "keywords": ["openclaw", "plugin", "context-engine", "memory", "vector", "sqlite"],
  "author": "Evan Coleman",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/evandcoleman/openclaw-plugin-lossless-context"
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "*",
    "openclaw": ">=2026.3.7"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "sqlite-vec": "^0.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "openclaw": "latest",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
